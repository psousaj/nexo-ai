# ===========================================
# Evolution API - Dev local para Nexo
# ===========================================

# Server
SERVER_NAME=evolution
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8080

# Auth
AUTHENTICATION_API_KEY=change-me
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

# Database (externo)
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://user:password@host:5432/evolution_api
DATABASE_CONNECTION_CLIENT_NAME=nexo_evolution_dev
DATABASE_ENABLED=true

# Redis (externo)
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://user:password@host:6379/6
CACHE_REDIS_PREFIX_KEY=nexo-evolution
CACHE_REDIS_SAVE_INSTANCES=true
CACHE_LOCAL_ENABLED=false

# Webhook global desligado (Nexo configura por instância)
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=

# Qualidade de vida em dev
TELEMETRY_ENABLED=false
LANGUAGE=pt-BR
