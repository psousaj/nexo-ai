{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@nexo/typescript-config/base.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"@/*": [
				"./src/*"
			]
		},
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}