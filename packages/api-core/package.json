{
    "name": "@nexo/api-core",
    "version": "0.1.0",
    "description": "Framework-agnostic business logic for Nexo AI (shared between Hono and Elysia apps)",
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./*": "./src/*.ts",
        "./*/*": "./src/*/*.ts",
        "./*/*/*": "./src/*/*/*.ts",
        "./adapters/messaging": "./src/adapters/messaging/index.ts",
        "./db": "./src/db/index.ts",
        "./db/schema": "./src/db/schema/index.ts",
        "./schemas": "./src/schemas/index.ts",
        "./services/ai": "./src/services/ai/index.ts",
        "./services/enrichment": "./src/services/enrichment/index.ts",
        "./services/tools": "./src/services/tools/index.ts",
        "./services/whatsapp": "./src/services/whatsapp/index.ts",
        "./types": "./src/types/index.ts"
    },
    "typesVersions": {
        "*": {
            "*": [
                "src/*",
                "src/*/index.ts"
            ]
        }
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@ai-sdk/openai": "^3.0.41",
        "@bull-board/api": "^6.16.4",
        "@google/generative-ai": "^0.24.1",
        "@langfuse/openai": "^4.6.1",
        "@langfuse/tracing": "^4.6.1",
        "@nexo/env": "workspace:*",
        "@nexo/otel": "workspace:*",
        "@nexo/shared": "workspace:*",
        "@openfeature/server-sdk": "^1.20.2",
        "@sentry/core": "^10.39.0",
        "@toon-format/toon": "^2.1.0",
        "@whiskeysockets/baileys": "7.0.0-rc.9",
        "ai": "^6.0.49",
        "ai-gateway-provider": "^3.1.1",
        "better-auth": "^1.4.17",
        "bullmq": "^5.70.4",
        "chrono-node": "^2.9.0",
        "discord.js": "^14.25.1",
        "drizzle-orm": "^0.45.1",
        "google-auth-library": "^10.5.0",
        "googleapis": "^171.4.0",
        "handlebars": "^4.7.8",
        "ioredis": "^5.9.2",
        "js-yaml": "^4.1.1",
        "langfuse": "^3.0.0",
        "node-nlp": "5.0.0-alpha.5",
        "openai": "^6.16.0",
        "pg": "^8.17.2",
        "pino": "^10.3.0",
        "pino-pretty": "^13.1.3",
        "postgres": "^3.4.8",
        "resend": "^6.8.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@nexo/typescript-config": "workspace:*",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^20.19.30",
        "@types/pg": "^8.16.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    }
}