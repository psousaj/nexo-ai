DATABASE_URL=postgres://user:pass@localhost:5432/nexo

# Core
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:5173

# === Dashboard ===
NUXT_PUBLIC_API_URL=http://localhost:3001
NUXT_PUBLIC_AUTH_BASE_URL=http://localhost:3001
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram Bot (obter em https://t.me/BotFather)
BOT_TOKEN_TELEGRAM=

# === AI Providers (pelo menos um) ===
OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=

# === Cloudflare Workers AI (STT) ===
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# === Google Cloud TTS (free tier: 1M chars/mês) ===
# GOOGLE_TTS_API_KEY=

# === Serviços (opcional) ===
SENTRY_DSN=
SENTRY_ENABLED=false
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
OTEL_EXPORTER_OTLP_ENDPOINT=

# === Enrichment (opcional — tools desativadas se não configuradas) ===
