{
	"name": "@nexo/api-elysia",
	"version": "0.1.0",
	"description": "Nexo AI API — Elysia + Bun runtime",
	"type": "module",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"build": "bun build --compile --outfile server src/index.ts",
		"start": "./server",
		"start:bun": "bun run src/index.ts",
		"test": "vitest --run --config vitest.config.ts",
		"test:watch": "vitest --config vitest.config.ts --watch",
		"typecheck": "tsc --noEmit",
		"train:nexo": "bun run src/services/message-analysis/training/nexo-trainer.ts"
	},
	"dependencies": {
		"@bull-board/api": "^6.16.4",
		"@bull-board/hono": "^6.16.4",
		"@elysiajs/cors": "^1.3.1",
		"@elysiajs/cron": "^1.3.0",
		"@elysiajs/openapi": "^1.4.14",
		"@elysiajs/opentelemetry": "^1.3.0",
		"@elysiajs/server-timing": "^1.3.0",
		"@nexo/api-core": "workspace:*",
		"@nexo/env": "workspace:*",
		"@nexo/otel": "workspace:*",
		"@nexo/shared": "workspace:*",
		"@sentry/node": "^10.39.0",
		"drizzle-orm": "^0.45.1",
		"elysia": "^1.3.0",
		"hono": "^4.11.5"
	},
	"devDependencies": {
		"@nexo/typescript-config": "workspace:*",
		"@types/node": "^20.19.30",
		"bun-types": "latest",
		"typescript": "^5.9.3",
		"vitest": "^2.1.9"
	}
}
